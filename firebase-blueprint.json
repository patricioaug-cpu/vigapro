{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and access status",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "trial_start": { "type": "string", "format": "date-time" },
        "access_granted": { "type": "boolean" },
        "request_pending": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "trial_start"]
    },
    "Calculation": {
      "title": "Calculation",
      "description": "Stored beam, pillar, or slab calculation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["beam", "pillar", "slab"] },
        "input_data": { "type": "object" },
        "result_data": { "type": "object" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "input_data", "result_data", "created_at"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "calculations/{calcId}": {
      "schema": "Calculation",
      "description": "Calculation history document"
    }
  }
}
